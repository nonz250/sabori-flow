{
  "name": "sabori-flow",
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "sabori-flow": "./dist/index.js"
  },
  "files": [
    "dist/",
    "prompts/",
    "launchd/*.plist.template",
    "config.yml.example"
  ],
  "scripts": {
    "build": "tsc",
    "worker": "node dist/worker.js",
    "dev:worker": "tsx src/worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "@inquirer/prompts": "^7.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@types/node": "^22.0.0"
  }
}
