{
  "name": "sabori-flow",
  "version": "0.2.0",
  "description": "Automated GitHub Issue resolver powered by Claude Code CLI",
  "type": "module",
  "license": "MIT",
  "author": "nonz250",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nonz250/sabori-flow.git"
  },
  "homepage": "https://github.com/nonz250/sabori-flow#readme",
  "bugs": {
    "url": "https://github.com/nonz250/sabori-flow/issues"
  },
  "keywords": [
    "github",
    "issue",
    "automation",
    "claude",
    "ai",
    "workflow",
    "launchd"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "sabori-flow": "./dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "prompts/",
    "launchd/*.plist.template",
    "config.yml.example"
  ],
  "scripts": {
    "build": "tsc",
    "worker": "node dist/worker.js",
    "dev:worker": "tsx src/worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "@inquirer/prompts": "^7.0.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "tsx": "^4.0.0",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "@types/node": "^24.0.0"
  }
}
