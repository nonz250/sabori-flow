# Target repositories
repositories:
  - owner: your-org
    repo: example-app
    local_path: /Users/you/projects/example-app
    labels:
      plan:
        trigger: claude/plan
        in_progress: "claude/plan:in-progress"
        done: "claude/plan:done"
        failed: "claude/plan:failed"
      impl:
        trigger: claude/impl
        in_progress: "claude/impl:in-progress"
        done: "claude/impl:done"
        failed: "claude/impl:failed"
    priority_labels:
      - priority:high
      - priority:low

# Execution settings
execution:
  max_parallel: 1
  # max_issues_per_repo: 1  # Max issues per repository (default: 1)
  # autonomy: interactive    # interactive / auto / full / sandboxed (default: interactive)
  #                          # auto: Claude Code --permission-mode auto (v2.1.83+, Max/Team/Enterprise)
  #                          # sandboxed: reserved for future non-Claude CLIs, currently behaves like interactive
  # interval_minutes: 60  # Scheduled execution interval in minutes (10-1440, default: 60)
  # timeout_minutes: 60   # Claude CLI execution timeout in minutes (1-240, default: 60)

# Display language
# language: ja  # ja / en (default: ja)
