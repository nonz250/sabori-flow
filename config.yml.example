# 対象リポジトリ
repositories:
  - owner: nonz250
    repo: example-app
    local_path: /Users/you/projects/example-app
    labels:
      plan:
        trigger: claude/plan
        in_progress: "claude/plan:in-progress"
        done: "claude/plan:done"
        failed: "claude/plan:failed"
      impl:
        trigger: claude/impl
        in_progress: "claude/impl:in-progress"
        done: "claude/impl:done"
        failed: "claude/impl:failed"
    priority_labels:
      - priority:high
      - priority:low

# 実行設定
execution:
  max_parallel: 1
  # max_issues_per_repo: 1  # リポジトリあたりの Issue 処理上限（省略時は 1）
  # autonomy: interactive    # full / sandboxed / interactive（省略時は interactive）

# 表示言語
# language: ja  # ja / en（省略時は ja）
